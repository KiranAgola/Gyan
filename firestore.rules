rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for Account
    function isValidAccount(data) {
      return data.keys().hasAll(['name', 'type', 'ownerId']) &&
             data.keys().size() <= 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type in ['income', 'expense'] &&
             data.ownerId == request.auth.uid;
    }

    match /accounts/{accountId} {
      allow get: if isOwner(resource.data.ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidAccount(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && 
                      isValidAccount(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId &&
                      request.resource.data.type == resource.data.type;
      allow delete: if isOwner(resource.data.ownerId);
    }

    // Validation for Transaction
    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'date', 'accountId', 'type', 'ownerId']) &&
             data.keys().size() <= 7 &&
             data.amount is number &&
             data.date is string &&
             data.accountId is string &&
             data.type in ['income', 'expense'] &&
             data.ownerId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow get: if isOwner(resource.data.ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && 
                      isValidTransaction(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner(resource.data.ownerId);
    }
  }
}
